{
  "integrations": {
    "spotify": {
      "enabled": true,
      "available": true,
      "transport": "stub",
      "defaultTrackTitle": "Night Drive",
      "defaultArtist": "Primea FM",
      "defaultAlbum": "Sample Rotation",
      "backgroundEnrichmentEnabled": true,
      "pollCadenceMinutes": 10
    },
    "freshRss": {
      "enabled": true,
      "available": true,
      "transport": "stub",
      "backgroundEnrichmentEnabled": true,
      "pollCadenceMinutes": 30,
      "dailyTopItems": 3
    }
  },
  "sensors": {
    "media": {
      "enabled": true,
      "backend": "powershell",
      "pollIntervalMs": 2500,
      "probeTimeoutMs": 1800,
      "includeOutputDevice": true
    }
  },
  "memory": {
    "enabled": true,
    "adapterMode": "obsidian",
    "mutationTransparencyPolicy": "logged",
    "writeLegacyJsonl": false
  },
  "openclaw": {
    "enabled": true,
    "transport": "stub",
    "mode": "online",
    "agentId": "main",
    "agentTimeoutMs": 60000,
    "baseUrl": "http://127.0.0.1:18789/bridge/dialog",
    "timeoutMs": 1200,
    "retryCount": 0,
    "authTokenRef": "PET_OPENCLAW_AUTH_TOKEN",
    "authToken": null,
    "allowNonLoopback": false
  },
  "paths": {
    "localWorkspaceRoot": ".",
    "openClawWorkspaceRoot": null,
    "obsidianVaultRoot": "W:\\AI\\OpenClaw\\Memory\\Vault"
  },
  "roaming": {
    "mode": "desktop",
    "zone": "desk-center",
    "zoneRect": null
  },
  "ui": {
    "diagnosticsEnabled": false,
    "characterScalePercent": 100,
    "characterHitboxScalePercent": 100
  },
  "wardrobe": {
    "activeAccessories": []
  },
  "inventory": {
    "quickProps": []
  },
  "dialog": {
    "alwaysShowBubble": true
  }
}
