{
  "integrations": {
    "spotify": {
      "backgroundEnrichmentEnabled": true,
      "pollCadenceMinutes": 10
    },
    "freshRss": {
      "backgroundEnrichmentEnabled": true,
      "pollCadenceMinutes": 30
    }
  },
  "sensors": {
    "media": {
      "enabled": true,
      "backend": "powershell",
      "pollIntervalMs": 2500,
      "probeTimeoutMs": 1800,
      "includeOutputDevice": true
    }
  },
  "memory": {
    "enabled": true,
    "adapterMode": "obsidian",
    "mutationTransparencyPolicy": "logged",
    "writeLegacyJsonl": true
  },
  "openclaw": {
    "enabled": true,
    "transport": "http",
    "mode": "online",
    "baseUrl": "http://127.0.0.1:18789/bridge/dialog",
    "timeoutMs": 1200,
    "retryCount": 1,
    "authTokenRef": "PET_OPENCLAW_AUTH_TOKEN",
    "authToken": null,
    "allowNonLoopback": false,
    "petCommandSharedSecretRef": "PET_OPENCLAW_PET_COMMAND_SECRET",
    "petCommandSharedSecret": null,
    "petCommandKeyId": "local-default"
  },
  "paths": {
    "localWorkspaceRoot": ".",
    "openClawWorkspaceRoot": "\\\\wsl$\\Ubuntu\\home\\user\\openclaw-workspace",
    "obsidianVaultRoot": "W:\\AI\\PrimeaVault"
  },
  "ui": {
    "diagnosticsEnabled": false,
    "characterScalePercent": 100,
    "characterHitboxScalePercent": 100
  }
}
