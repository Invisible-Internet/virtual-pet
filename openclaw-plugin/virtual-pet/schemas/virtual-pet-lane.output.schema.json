{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Virtual Pet Lane Tool Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mode",
    "contractVersion",
    "action",
    "proposedActions"
  ],
  "properties": {
    "mode": {
      "type": "string",
      "enum": [
        "tool",
        "gateway"
      ]
    },
    "contractVersion": {
      "type": "string",
      "enum": [
        "vp-plugin-lane-v1"
      ]
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "route",
        "payload"
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "virtual_pet_lane_call"
        },
        "route": {
          "type": "string",
          "const": "virtual_pet_lane_call"
        },
        "payload": {
          "type": "object"
        }
      }
    },
    "proposedActions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object"
      }
    }
  }
}
